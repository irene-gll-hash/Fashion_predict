APP_ENV=local
APP_DEBUG=true

USE_MOCK_APIFY=true
USE_MOCK_VISION=true
USE_MOCK_GIGACHAT=true

STORAGE_MODE=json

DATA_DIR=./data
RAW_DATA_DIR=./data/raw
MEDIA_DIR=./data/media
PROCESSED_DATA_DIR=./data/processed

APIFY_TOKEN=
APIFY_ACTOR_ID=apify/instagram-scraper
APIFY_RESULTS_LIMIT=10

GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VISION_ENABLED=false

GIGACHAT_ENABLED=false
GIGACHAT_MODEL=GigaChat-Lite
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fashion_ai
POSTGRES_USER=fashion_user
POSTGRES_PASSWORD=

QDRANT_ENABLED=false
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=fashion_trends

PYTRENDS_ENABLED=false
PYTRENDS_REGION=RU
PYTRENDS_TIMEFRAME=today 3-m